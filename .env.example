# Psychology Chatbot Advanced - Environment Configuration

# ===== API Keys =====
# Get your GROQ_API_KEY from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Get your HUGGINGFACE_API_KEY from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Get your SERPER_API_KEY from: https://serper.dev
SERPER_API_KEY=your_serper_api_key_here

# ===== Backend Configuration =====
PYTHONUNBUFFERED=1
DEBUG=false
LOG_LEVEL=INFO

# ===== Frontend Configuration =====
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# ===== Azure Configuration (for deployment) =====
AZURE_SUBSCRIPTION_ID=your_subscription_id
AZURE_RESOURCE_GROUP=psychology-chatbot-rg
AZURE_LOCATION=eastus

# ===== Container Registry (for deployment) =====
REGISTRY_NAME=psychologychatbot
REGISTRY_LOGIN_SERVER=your_registry.azurecr.io

# ===== Environment =====
# Options: dev, staging, prod
ENVIRONMENT=dev
