# Environment file for Docker deployment
# Copy this to .env and fill in your API keys

# ============================================
# REQUIRED: LLM API Keys
# ============================================

# Groq API Key (required)
# Get from: https://console.groq.com/
GROQ_API_KEY=your-groq-api-key-here

# ============================================
# OPTIONAL: Additional API Keys
# ============================================

# HuggingFace Token (optional, for model access)
HUGGINGFACE_API_KEY=

# Serper API Key (optional, for web search)
SERPER_API_KEY=

# Tavily API Key (optional, for research)
TAVILY_API_KEY=

# ============================================
# Environment & Logging
# ============================================

# Environment: production, staging, development
ENV=production

# Python logging
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1

# Streamlit logging level
STREAMLIT_LOGGER_LEVEL=info

# Application logging level
LOG_LEVEL=INFO

# ============================================
# Database Configuration
# ============================================

# Database URL (SQLite)
DATABASE_URL=sqlite:///./data/psychology_chatbot.db

# Enable query logging
SQL_ECHO=false

# ============================================
# Server Configuration
# ============================================

# Backend server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=2

# Frontend (Streamlit)
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_SERVER_HEADLESS=true

# ============================================
# Security
# ============================================

# CORS settings
CORS_ORIGINS=["http://localhost:8501", "http://localhost:3000"]
CORS_ALLOW_CREDENTIALS=true

# Session timeout (minutes)
SESSION_TIMEOUT=30

# ============================================
# Feature Flags
# ============================================

# Enable crisis detection
ENABLE_CRISIS_DETECTION=true

# Enable assessment features
ENABLE_ASSESSMENTS=true

# Enable report generation
ENABLE_REPORTS=true

# ============================================
# Performance Tuning
# ============================================

# Redis cache (optional)
REDIS_URL=

# Cache TTL in seconds
CACHE_DEFAULT_TTL=3600

# Vector store embedding model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ============================================
# File Paths
# ============================================

# Data directory
DATA_DIR=/app/data

# Generated reports directory
REPORTS_DIR=/app/generated_reports

# Logs directory
LOGS_DIR=/app/logs

# Vector store directory
VECTOR_STORE_DIR=/app/data/vector_store

# ============================================
# Docker-specific settings
# ============================================

# Container environment
DOCKER_ENABLED=true

# Network name
DOCKER_NETWORK=psychology-net

# Container names
CONTAINER_BACKEND=psychology-chatbot-backend
CONTAINER_FRONTEND=psychology-chatbot-frontend
