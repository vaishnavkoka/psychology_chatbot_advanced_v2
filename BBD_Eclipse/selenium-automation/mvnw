#
# Apache Maven Wrapper Shell Script
# Optional ENV vars
#   M2_HOME - location of maven2 to use (default searches $PATH for mvn and use its parent dir)
#   MAVEN_SKIP_RC - flag to disable loading of mavenrc files
# Optional system properties
#   maven.home - M2_HOME root folder. If set, then the pure java implementation is used
#   maven.multiModuleProjectDirectory - root folder. If set, then the sources will be read from this folder
#
# See other scripts in bin folder for more details
#-----

# Just use the defaults set in the wrapper itself
exec "$JAVA_HOME/bin/java" \
  $MAVEN_OPTS \
  -classpath "$(dirname -- "$0")/.mvn/wrapper/maven-wrapper.jar" \
  "-Dmaven.home=$(dirname -- "$0")/.mvn/wrapper" \
  "-Dclassworlds.conf=$(dirname -- "$0")/.mvn/wrapper/m2.conf" \
  "org.apache.maven.wrapper.MavenWrapperMain" "$@"
