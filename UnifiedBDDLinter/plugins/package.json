{
  "name": "unified-bdd-linter",
  "displayName": "Unified BDD Linter",
  "description": "Complete Gherkin validation combining gherkin-lint, cuke_linter, and quality checks",
  "version": "1.0.0",
  "publisher": "vaishnavkoka",
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Linters",
    "Testing"
  ],
  "keywords": [
    "gherkin",
    "cucumber",
    "bdd",
    "feature",
    "lint"
  ],
  "activationEvents": [
    "onLanguage:gherkin",
    "onCommand:unified-bdd-linter.lint"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "unified-bdd-linter.lint",
        "title": "Lint Gherkin File",
        "category": "Unified BDD Linter"
      },
      {
        "command": "unified-bdd-linter.autofix",
        "title": "Auto-fix Gherkin File",
        "category": "Unified BDD Linter"
      },
      {
        "command": "unified-bdd-linter.lintFolder",
        "title": "Lint All Features in Folder",
        "category": "Unified BDD Linter"
      }
    ],
    "keybindings": [
      {
        "command": "unified-bdd-linter.lint",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l",
        "when": "editorLangId == gherkin"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "unified-bdd-linter.lint",
          "when": "editorLangId == gherkin",
          "group": "9_cutcopypaste"
        },
        {
          "command": "unified-bdd-linter.autofix",
          "when": "editorLangId == gherkin",
          "group": "9_cutcopypaste"
        }
      ],
      "explorer/context": [
        {
          "command": "unified-bdd-linter.lintFolder",
          "when": "explorerResourceIsFolder"
        }
      ]
    },
    "configuration": [
      {
        "title": "Unified BDD Linter",
        "properties": {
          "unified-bdd-linter.enable": {
            "type": "boolean",
            "default": true,
            "description": "Enable Unified BDD Linter"
          },
          "unified-bdd-linter.linterPath": {
            "type": "string",
            "description": "Path to linter.py (auto-detected if empty)"
          },
          "unified-bdd-linter.minSeverity": {
            "type": "string",
            "enum": [
              "info",
              "warning",
              "error"
            ],
            "default": "warning",
            "description": "Minimum violation severity to show"
          },
          "unified-bdd-linter.autoLintOnSave": {
            "type": "boolean",
            "default": true,
            "description": "Lint files automatically on save"
          },
          "unified-bdd-linter.showSuggestions": {
            "type": "boolean",
            "default": true,
            "description": "Show fix suggestions in CodeLens"
          }
        }
      }
    ],
    "languages": [
      {
        "id": "gherkin",
        "aliases": [
          "Gherkin",
          "Cucumber"
        ],
        "extensions": [
          ".feature"
        ]
      }
    ]
  },
  "scripts": {
    "lint": "eslint .",
    "test": "node ./test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.70.0",
    "eslint": "^8.0.0"
  },
  "dependencies": {},
  "repository": {
    "type": "git",
    "url": "https://github.com/vaishnavkoka/RE4BDD.git"
  },
  "bugs": {
    "url": "https://github.com/vaishnavkoka/RE4BDD/issues"
  },
  "icon": "media/icon.png"
}
